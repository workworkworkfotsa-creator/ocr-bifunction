# Python
__pycache__/
*.py[cod]
.venv/

# uv
.uv/

# Extracted text dumps from the smoke runner — derived, never committed
outputs/

# Real input documents — may contain personal data (CI, factures); keep out of git
inputs/

# D1 store (records + status) — the SQLite proxy holds extracted fields (PII), never committed
*.sqlite
*.sqlite-journal

# Async spool: uploaded document bytes waiting for the watchdog worker (PII), purged on
# terminal state — never committed. The watchdog PID lockfile is runtime state.
spool/
*.pid

# Local OCR model weights (GGUF) — large binaries, never committed
models/

# Reference reading (3rd-party blog posts, copyrighted) — not ours to publish
docs/Brainstoms/

# Working briefs + cross-project meta-cadrage (Claude.ai discussions) — internal, not public
docs/briefs/

# Local binaries — large / platform-specific, never committed. The llama-swap CONFIG is
# TRACKED (it is the portable deployment contract: project-relative paths, no PII).
tools/llama-swap/*.exe
tools/llamacpp/
